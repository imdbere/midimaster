{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidiMaster",
  "version": "0.1.0",
  "identifier": "com.yagnilabs.midimaster",
  "build": {
    "devUrl": "http://localhost:5173/desktop.html",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Midi Master",
        "url": "desktop.html",
        "width": 480,
        "height": 600,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "config/settings.yaml": "config/settings.yaml",
      "config/surfaces/*.yaml": "config/surfaces/",
      "../dist/index.html": "www/index.html",
      "../dist/desktop.html": "www/desktop.html",
      "../dist/assets/*": "www/assets/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwNzcyMjEyODEwNzEwQTcKUldTbkVBZUJFaUozUU4rdUVkVnVpSlpMd01oT2g4YXZmZ2l5dG02QkZmZXJUMU8wZmlLbDAxVk4K",
      "endpoints": [
        "https://github.com/imdbere/midimaster/releases/latest/download/latest.json"
      ]
    }
  }
}
